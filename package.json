{
  "name": "ocr-web-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "PP-OCRv5 inference for browser & Electron",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "dev": "pnpm -r --parallel --filter \"./packages/*\" run dev",
    "test": "pnpm -r --filter \"./packages/*\" run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "spike": "pnpm --filter @ocr-web-spike/det-hello run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
