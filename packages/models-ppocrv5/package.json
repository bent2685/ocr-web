{
	"name": "@ocr-web/models-ppocrv5",
	"version": "0.1.1",
	"publishConfig": { "access": "public" },
	"repository": {
		"type": "git",
		"url": "https://github.com/bent2685/ocr-web.git",
		"directory": "packages/models-ppocrv5"
	},
	"homepage": "https://github.com/bent2685/ocr-web#readme",
	"bugs": "https://github.com/bent2685/ocr-web/issues",
	"description": "PP-OCRv5 ONNX model URLs (det/cls/rec/dict) for @ocr-web/core",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": ["dist", "README.md"],
	"sideEffects": false,
	"scripts": {
		"build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean"
	},
	"devDependencies": {
		"tsup": "^8.3.0"
	},
	"keywords": ["ocr", "ppocrv5", "onnx", "models"],
	"license": "MIT"
}
