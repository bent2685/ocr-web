{
	"name": "@ocr-web/pdf",
	"version": "0.3.0",
	"publishConfig": { "access": "public" },
	"repository": {
		"type": "git",
		"url": "https://github.com/bent2685/ocr-web.git",
		"directory": "packages/pdf"
	},
	"homepage": "https://github.com/bent2685/ocr-web#readme",
	"bugs": "https://github.com/bent2685/ocr-web/issues",
	"description": "PDF text extraction via @ocr-web/core (renders pages with pdfjs-dist, OCRs each page)",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": ["dist", "README.md"],
	"sideEffects": false,
	"scripts": {
		"build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean"
	},
	"peerDependencies": {
		"@ocr-web/core": "^0.2.0"
	},
	"dependencies": {
		"pdfjs-dist": "^4.7.76"
	},
	"devDependencies": {
		"@ocr-web/core": "workspace:*",
		"tsup": "^8.3.0"
	},
	"keywords": ["ocr", "pdf", "pdfjs", "ppocrv5", "browser"],
	"license": "MIT"
}
